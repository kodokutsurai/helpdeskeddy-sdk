{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "lib": ["ES2020"],

    "moduleResolution": "NodeNext",
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"]
}
